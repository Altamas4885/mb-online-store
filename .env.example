# Copy this file to `.env` for local development with `netlify dev`.
# NEVER commit the real `.env` file — it's already in .gitignore.
#
# In production (Netlify dashboard), set these under:
# Site settings -> Environment variables
# Do NOT prefix these with VITE_ — they must stay server-side only,
# accessible exclusively to the Netlify Functions in netlify/functions/.

RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
